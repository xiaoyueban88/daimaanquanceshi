<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="edp.davinci.dao.WidgetPublishMapper">
    <insert id="insertBatch" useGeneratedKeys="true" keyProperty="id">
        insert into widget_publish
        (`id`,`name`,`description`, view_id, `project_id`, `type`, `publish`,`config`,`create_by`,`create_time`)
        VALUES
        <foreach collection="list" item="record" index="index" separator=",">
            (
            #{record.id,jdbcType=BIGINT},
            #{record.name,jdbcType=VARCHAR},
            #{record.description,jdbcType=VARCHAR},
            #{record.viewId,jdbcType=BIGINT},
            #{record.projectId,jdbcType=BIGINT},
            #{record.type,jdbcType=BIGINT},
            #{record.publish,jdbcType=BIT},
            #{record.config,jdbcType=LONGVARCHAR},
            #{record.createBy,jdbcType=BIGINT},
            #{record.createTime,jdbcType=TIMESTAMP}
            )
        </foreach>
    </insert>

    <delete id="deleteBatch" parameterType="java.util.Set">
        DELETE FROM widget_publish WHERE
        <if test="set != null and set.size > 0">
            id in
            <foreach collection="set" index="index" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
        <if test="set == null or set.size == 0">
            1=0
        </if>

    </delete>

    <select id="getShareWidgetsByIds" resultType="edp.davinci.dto.shareDto.ShareWidget" parameterType="java.util.Set">
        SELECT
          w.*,
          v.model
        from widget_publish w
        LEFT JOIN view v
        on v.id = w.view_id
        WHERE
        <if test="list != null and list.size > 0">
            w.id in
            <foreach collection="list" index="index" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
        <if test="list == null or list.size == 0">
            1=0
        </if>
    </select>

    <select id="getWidgetNamesByIds" resultType="edp.davinci.model.Widget" parameterType="java.util.Set">
        SELECT
         id,  `name`
        from widget_publish
        WHERE
        <if test="list != null and list.size > 0">
            id in
            <foreach collection="list" index="index" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
        <if test="list == null or list.size == 0">
            1=0
        </if>
    </select>

    <select id="getSimpleWidgetInfo" resultType="edp.davinci.model.Widget" parameterType="java.util.Set">
        select id, `name` from widget_publish where
        <if test="list != null and list.size > 0">
            id in
            <foreach collection="list" index="index" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
    </if>
        <if test="list == null or list.size == 0">
            1=0
        </if>
    </select>

</mapper>