<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="edp.davinci.dao.WidgetContainerMapper">
    <insert id="insert" parameterType="edp.davinci.model.WidgetContainer">
        <selectKey resultType="java.lang.Long" order="AFTER" keyProperty="id">
            SELECT LAST_INSERT_ID() AS id
        </selectKey>
        insert `widget_container`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            `name`,
            `description`,
            `config`,
            `dispose`,
            `project_id`,
            `folder_id`,
            `create_by`,
            `create_time`
        </trim>
        values
        <trim prefix=" (" suffix=")" suffixOverrides=",">
            #{name, jdbcType=VARCHAR},
            #{description, jdbcType=VARCHAR},
            #{config, jdbcType=VARCHAR},
            #{dispose, jdbcType=VARCHAR},
            #{projectId,jdbcType=BIGINT},
            #{folderId,jdbcType=BIGINT},
            #{createBy,jdbcType=BIGINT},
            #{createTime,jdbcType=TIMESTAMP}
        </trim>
    </insert>

    <select id="getByIds" resultType="edp.davinci.model.WidgetContainer" parameterType="java.util.Set">
        select * from widget_container where
        <if test="list != null and list.size > 0">
            id in
            <foreach collection="list" index="index" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
        <if test="list == null or list.size == 0">
            1=0
        </if>
    </select>

    <select id="getIdSetByIds" resultType="java.lang.Long" parameterType="java.util.Set">
        select id from widget_container where
        <if test="set != null and set.size > 0">
            id in
            <foreach collection="set" index="index" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
        <if test="set == null or set.size == 0">
            1=0
        </if>
    </select>

    <update id="updateFolderIdBatch">
        update widget_container set `folder_id` =
        <foreach collection="list" item="record" index="index" separator=" " open="case id" close="end">
            when #{record.id} then #{record.folderId}
        </foreach>
        where id in
        <foreach collection="list" index="index" item="record" separator="," open="(" close=")">
            #{record.id,jdbcType=BIGINT}
        </foreach>
    </update>

    <update id="updateDisposeBatch">
        update widget_container set `dispose` =
        <foreach collection="list" item="record" index="index" separator=" " open="case id" close="end">
            when #{record.id} then #{record.dispose}
        </foreach>
        where id in
        <foreach collection="list" index="index" item="record" separator="," open="(" close=")">
            #{record.id,jdbcType=BIGINT}
        </foreach>
    </update>

</mapper>