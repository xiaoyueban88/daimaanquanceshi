<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="edp.davinci.dao.MemDashboardWidgetPublishMapper">
    <insert id="insertBatch" useGeneratedKeys="true" keyProperty="id">
        insert into mem_dashboard_widget_publish
        (`id`,`dashboard_id`,`widget_Id`,`x`,`y`,`width`,`height`,`frequency`,`polling`,`create_by`,`create_time`,`widget_type`)
        VALUES
        <foreach collection="list" item="record" index="index" separator=",">
            (
            #{record.id,jdbcType=BIGINT},
            #{record.dashboardId,jdbcType=BIGINT},
            #{record.widgetId,jdbcType=BIGINT},
            #{record.x,jdbcType=INTEGER},
            #{record.y,jdbcType=INTEGER},
            #{record.width,jdbcType=INTEGER},
            #{record.height,jdbcType=INTEGER},
            #{record.frequency,jdbcType=INTEGER},
            #{record.polling,jdbcType=BIT},
            #{record.createBy,jdbcType=BIGINT},
            #{record.createTime,jdbcType=TIMESTAMP},
            #{record.widgetType,jdbcType=TINYINT}
            )
        </foreach>
    </insert>
</mapper>